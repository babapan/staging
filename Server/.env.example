# ─────────────────────────────────────────────────────────────────────────────
# max99 / Migme — Environment Variables (Production AWS)
#
# Salin file ini ke .env dan isi nilainya:
#   cp .env.example .env && nano .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
#
# Pilihan 1 — PostgreSQL self-hosted Docker (direkomendasikan)
# Setelah migrasi dari Neon, gunakan format ini:
DATABASE_URL=postgresql://migme:POSTGRES_PASSWORD@postgres:5432/migmedb
#
# Pilihan 2 — Neon (cloud, pakai ini sebelum migrasi)
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── PostgreSQL Self-Hosted (docker-compose service: postgres) ──────────────────
# Dipakai oleh container max99-postgres
# Wajib diisi jika pakai Pilihan 1 di atas
POSTGRES_DB=migmedb
POSTGRES_USER=migme
POSTGRES_PASSWORD=ganti_dengan_password_kuat_min_32_karakter

# ── Session & Redis ───────────────────────────────────────────────────────────
SESSION_SECRET=ganti_dengan_random_string_panjang
REDIS_URL=redis://redis:6379
NODE_ENV=production
# Set ke "true" HANYA jika server sudah pakai HTTPS (domain + SSL)
COOKIE_SECURE=false

# ── Auth ──────────────────────────────────────────────────────────────────────
# Buat dengan: openssl rand -hex 64
JWT_SECRET=ganti_dengan_random_string_lain
ADMIN_JWT_SECRET=ganti_dengan_admin_jwt_secret
INTERNAL_API_KEY=migme-internal-admin-2024

# ── Self-hosted CDN (img.chatmeapp.my.id) ─────────────────────────────────────
# Subdomain untuk serve file gambar & video yang diupload user.
#
# Setup DNS:
#   A  img.chatmeapp.my.id  →  IP_SERVER_AWS
#
# Setup nginx (jalankan di server):
#   sudo cp Server/nginx-img.conf /etc/nginx/sites-available/img
#   sudo ln -sf /etc/nginx/sites-available/img /etc/nginx/sites-enabled/
#   sudo certbot --nginx -d img.chatmeapp.my.id
#   sudo systemctl reload nginx
#
# Struktur folder di dalam container: /app/uploads/{subfolder}/filename
# Contoh: https://img.chatmeapp.my.id/gifts/gift_rose.png
IMG_BASE_URL=https://img.chatmeapp.my.id
UPLOADS_DIR=/app/uploads

# ── Email (Brevo) ─────────────────────────────────────────────────────────────
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx

# ── LiveKit — Dual Provider (Cloud + Self-hosted) ─────────────────────────────
#
# LIVEKIT_MODE mengontrol provider mana yang dipakai:
#   auto       → Cloud jika Cloud dikonfigurasi, else self-hosted (DEFAULT)
#   cloud      → Paksa LiveKit Cloud
#   selfhosted → Paksa self-hosted Docker
#
# Saat menit gratis LiveKit Cloud (10.000 mnt/bulan) habis:
#   Ganti LIVEKIT_MODE=selfhosted lalu restart server (docker compose restart backend)
#
LIVEKIT_MODE=auto

# ── LiveKit Cloud (primary — 10rb menit gratis/bulan) ─────────────────────────
# Buat project di: https://cloud.livekit.io
# Dashboard → Settings → API Keys
LIVEKIT_CLOUD_URL=wss://your-project.livekit.cloud
LIVEKIT_CLOUD_API_KEY=APIxxxxxxxxxxxxxxxxx
LIVEKIT_CLOUD_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LiveKit Self-Hosted (fallback — Docker Compose AWS) ───────────────────────
# Container livekit + Express pakai key/secret YANG SAMA.
# Buat key & secret acak:
#   openssl rand -hex 16   → API_KEY
#   openssl rand -hex 32   → API_SECRET
#
LIVEKIT_API_KEY=ganti_dengan_livekit_api_key
LIVEKIT_API_SECRET=ganti_dengan_livekit_api_secret

# URL self-hosted dikirim ke klien — harus bisa diakses dari internet
# Setelah setup nginx + certbot subdomain:
LIVEKIT_URL=wss://livekit.chatmeapp.my.id
