{
  "expo": {
    "name": "kyulive",
    "slug": "max99",
    "owner": "max222",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/max99_logo.png",
    "scheme": "max99",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.max99stag.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "max99 memerlukan akses mikrofon untuk fitur Live Party.",
        "UIBackgroundModes": [
          "audio",
          "voip"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/max99_logo.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.max99stag.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.READ_PHONE_STATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/max99_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/max99_logo.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Izinkan $(PRODUCT_NAME) mengakses kamera untuk live stream."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "max99 menggunakan lokasi kamu untuk menandai postingan dengan wilayah saat ini."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": false,
            "extraProguardRules": "-keep class org.webrtc.** { *; }\n-dontwarn org.webrtc.**\n-keep class com.oney.WebRTCModule.** { *; }\n-dontwarn com.oney.WebRTCModule.**\n-keep class io.livekit.** { *; }\n-dontwarn io.livekit.**\n-keep class expo.modules.** { *; }\n-dontwarn expo.modules.**\n-keep interface expo.modules.** { *; }\n-keep class com.facebook.react.** { *; }\n-dontwarn com.facebook.react.**\n-keep class com.swmansion.** { *; }\n-dontwarn com.swmansion.**\n-keepattributes *Annotation*,Signature,InnerClasses,EnclosingMethod"
          }
        }
      ],
      [
        "@livekit/react-native-expo-plugin",
        {
          "android": {
            "audioType": "communication"
          }
        }
      ],
      [
        "./plugins/withAbiFilter",
        {
          "abis": "arm64-v8a,armeabi-v7a"
        }
      ],
      "./plugins/withWebRTCDedup",
      "expo-video",
      "@react-native-google-signin/google-signin",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Izin kamera untuk live streaming",
          "enableMicrophonePermission": true,
          "enableFrameProcessors": false
        }
      ],
      "./plugins/withBeautyFilter"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a2e8c707-dcd3-4759-9a95-b1a6084d2fdb"
        
      }
    }
  }
}
